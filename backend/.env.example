# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000

# ============================================
# MONGODB CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/chatbox247
MONGODB_URI_CLOUD=mongodb+srv://username:password@cluster.mongodb.net/chatbox247

# ============================================
# JWT CONFIGURATION
# ============================================
# Access Token - short lived (15 minutes)
JWT_ACCESS_TOKEN_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m

# Refresh Token - long lived (7 days)
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_min_32_chars
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# GOOGLE OAUTH2 (for Gmail Email)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Email sender
EMAIL_FROM=noreply@chatbox247.com
EMAIL_FROM_NAME=ChatBox247

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_EXPIRES_IN=5m
OTP_LENGTH=6

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=15m
RATE_LIMIT_MAX_REQUESTS=100

# Auth rate limit (stricter)
AUTH_RATE_LIMIT_MAX=5

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ============================================
# FRONTEND URL
# ============================================
CLIENT_URL=http://localhost:5173
CLIENT_API_URL=http://localhost:5173/api

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=7d

# ============================================
# OPTIONAL: REDIS (for session/cache)
# ============================================
REDIS_URL=redis://localhost:6379
USE_REDIS=false
