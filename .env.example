# ============================================
# Docker Compose Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_mongodb_password

# JWT Secrets (generate secure random strings)
JWT_ACCESS_TOKEN_SECRET=generate_a_secure_random_string_at_least_32_characters
JWT_REFRESH_TOKEN_SECRET=generate_another_secure_random_string_at_least_32_characters

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Email
EMAIL_FROM=noreply@chatbox247.com
